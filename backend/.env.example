# Fitness AI - Backend Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fitness_ai

# JWT Secret - CHANGE THIS in production!
SECRET_KEY=your-super-secret-key-change-in-production

# AI / LLM Provider (OpenAI recommended to start)
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Vector DB (ChromaDB local storage)
CHROMA_PERSIST_DIR=./data/chroma_db

# PDF uploads
PDF_UPLOAD_DIR=./data/pdfs

# CORS origins (add your frontend URLs)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
